{
  "name": "patchcord",
  "version": "1.0.0",
  "type": "module",
  "main": "./node/patchcord.js",
  "types": "./node/patchcord.d.ts",
  "exports": {
    ".": {
      "types": "./node/patchcord.d.ts",
      "import": "./node/patchcord.js"
    }
  },
  "files": [
    "dist"
  ],
  "cpu": ["x64", "arm64"],
  "os": ["linux"],
  "scripts": {
    "build": "cargo build --release",
    "build:dist": "bash ./build-rs.sh",
    "test:node": "bun test node/test/*.test.mjs",
    "test:rust": "cargo test -- --include-ignored --nocapture",
    "test": "bun run test:rust && bun run test:node"
  }
}
